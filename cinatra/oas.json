          "type": "object"
        },
        {
          "title": "parentPackageName",
          "type": "string",
          "default": ""
        },
        {
          "title": "cinatra_run_id",
          "type": "string",
          "default": ""
        },
        {
          "title": "skillIds",
          "type": "array",
          "default": []
        }
