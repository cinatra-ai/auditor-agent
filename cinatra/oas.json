{
  "agentspec_version": "26.1.0",
  "component_type": "Flow",
  "id": "auditor-flow",
  "name": "Auditor Agent",
  "description": "Runs installed/explicit skills against a parent agent's data, surfaces structured suggestions for human review, and deterministically applies the accepted patches.",
  "metadata": {
    "cinatra": {
      "type": "flow",
      "packageName": "@cinatra-ai/auditor-agent",
      "docsRef": "docs/developer/wayflow-input-message-node-contract.md",
      "hitlScreens": [
        "@cinatra-ai/auditor-agent:review"
      ]
    }
  },
  "inputs": [
    {
      "title": "data",
      "type": "object"
    },
    {
      "title": "parentPackageName",
      "type": "string",
      "default": ""
    },
    {
      "title": "cinatra_run_id",
      "type": "string",
      "default": ""
    },
    {
      "title": "skillIds",
      "type": "array",
      "default": []
    }
  ],
  "outputs": [
    {
      "title": "mutatedData",
      "type": "object"
    }
  ],
  "start_node": {
    "$component_ref": "start"
  },
  "nodes": [
    {
      "$component_ref": "start"
    },
    {
      "$component_ref": "resolve_skills"
    },
    {
      "$component_ref": "run_skills"
    },
    {
      "$component_ref": "prep_list"
    },
    {
      "$component_ref": "review_gate"
    },
    {
      "$component_ref": "apply_exclusions"
    },
    {
      "$component_ref": "apply_patches"
    },
    {
      "$component_ref": "end"
    }
  ],
  "control_flow_connections": [
    {
      "component_type": "ControlFlowEdge",
      "name": "start_to_resolve_skills",
      "from_node": {
        "$component_ref": "start"
      },
      "to_node": {
        "$component_ref": "resolve_skills"
      }
    },
    {
      "component_type": "ControlFlowEdge",
      "name": "resolve_skills_to_run_skills",
      "from_node": {
        "$component_ref": "resolve_skills"
      },
      "to_node": {
        "$component_ref": "run_skills"
      }
    },
    {
      "component_type": "ControlFlowEdge",
      "name": "run_skills_to_prep_list",
      "from_node": {
        "$component_ref": "run_skills"
      },
      "to_node": {
        "$component_ref": "prep_list"
      }
    },
    {
      "component_type": "ControlFlowEdge",
      "name": "prep_list_to_review_gate",
      "from_node": {
        "$component_ref": "prep_list"
      },
      "to_node": {
        "$component_ref": "review_gate"
      }
    },
    {
      "component_type": "ControlFlowEdge",
      "name": "review_gate_to_apply_exclusions",
      "from_node": {
        "$component_ref": "review_gate"
      },
      "to_node": {
        "$component_ref": "apply_exclusions"
      }
    },
    {
      "component_type": "ControlFlowEdge",
      "name": "apply_exclusions_to_apply_patches",
      "from_node": {
        "$component_ref": "apply_exclusions"
      },
      "to_node": {
        "$component_ref": "apply_patches"
      }
    },
    {
      "component_type": "ControlFlowEdge",
      "name": "apply_patches_to_end",
      "from_node": {
        "$component_ref": "apply_patches"
      },
      "to_node": {
        "$component_ref": "end"
      }
    }
  ],
  "data_flow_connections": [
    {
      "component_type": "DataFlowEdge",
      "name": "start_to_resolve_skills_agent_run_id",
      "source_node": {
        "$component_ref": "start"
      },
      "source_output": "cinatra_run_id",
      "destination_node": {
        "$component_ref": "resolve_skills"
      },
      "destination_input": "agent_run_id"
    },
    {
      "component_type": "DataFlowEdge",
      "name": "start_to_resolve_skills_parentPackageName",
      "source_node": {
        "$component_ref": "start"
      },
      "source_output": "parentPackageName",
      "destination_node": {
        "$component_ref": "resolve_skills"
      },
      "destination_input": "parentPackageName"
    },
    {
      "component_type": "DataFlowEdge",
      "name": "start_to_resolve_skills_skillIds",
      "source_node": {
        "$component_ref": "start"
      },
      "source_output": "skillIds",
      "destination_node": {
        "$component_ref": "resolve_skills"
      },
      "destination_input": "skillIds"
    },
    {
      "component_type": "DataFlowEdge",
      "name": "start_to_resolve_skills_data",
      "source_node": {
        "$component_ref": "start"
      },
      "source_output": "data",
      "destination_node": {
        "$component_ref": "resolve_skills"
      },
      "destination_input": "data"
    },
    {
      "component_type": "DataFlowEdge",
      "name": "start_to_run_skills_agent_run_id",
      "source_node": {
        "$component_ref": "start"
      },
      "source_output": "cinatra_run_id",
      "destination_node": {
        "$component_ref": "run_skills"
      },
      "destination_input": "agent_run_id"
    },
    {
      "component_type": "DataFlowEdge",
      "name": "start_to_run_skills_parentPackageName",
      "source_node": {
        "$component_ref": "start"
      },
      "source_output": "parentPackageName",
      "destination_node": {
        "$component_ref": "run_skills"
      },
      "destination_input": "parentPackageName"
    },
    {
      "component_type": "DataFlowEdge",
      "name": "resolve_skills_to_run_skills_skillIds",
      "source_node": {
        "$component_ref": "resolve_skills"
      },
      "source_output": "skillIds",
      "destination_node": {
        "$component_ref": "run_skills"
      },
      "destination_input": "skillIds"
    },
    {
      "component_type": "DataFlowEdge",
      "name": "start_to_run_skills_data",
      "source_node": {
        "$component_ref": "start"
      },
      "source_output": "data",
      "destination_node": {
        "$component_ref": "run_skills"
      },
      "destination_input": "data"
    },
    {
      "component_type": "DataFlowEdge",
      "name": "start_to_apply_patches_agent_run_id",
      "source_node": {
        "$component_ref": "start"
      },
      "source_output": "cinatra_run_id",
      "destination_node": {
        "$component_ref": "apply_patches"
      },
      "destination_input": "agent_run_id"
    },
    {
      "component_type": "DataFlowEdge",
      "name": "start_to_apply_patches_data",
      "source_node": {
        "$component_ref": "start"
      },
      "source_output": "data",
      "destination_node": {
        "$component_ref": "apply_patches"
      },
      "destination_input": "data"
    },
    {
      "component_type": "DataFlowEdge",
      "name": "review_gate_reviewResult_to_apply_patches",
      "source_node": {
        "$component_ref": "review_gate"
      },
      "source_output": "reviewResult",
      "destination_node": {
        "$component_ref": "apply_patches"
      },
      "destination_input": "reviewResult"
    },
    {
      "component_type": "DataFlowEdge",
      "name": "apply_patches_to_end_mutatedData",
      "source_node": {
        "$component_ref": "apply_patches"
      },
      "source_output": "mutatedData",
      "destination_node": {
        "$component_ref": "end"
      },
      "destination_input": "mutatedData"
    },
    {
      "component_type": "DataFlowEdge",
      "name": "start_to_prep_list_agent_run_id",
      "source_node": {
        "$component_ref": "start"
      },
      "source_output": "cinatra_run_id",
      "destination_node": {
        "$component_ref": "prep_list"
      },
      "destination_input": "agent_run_id"
    },
    {
      "component_type": "DataFlowEdge",
      "name": "prep_list_prompts_to_review_gate",
      "source_node": {
        "$component_ref": "prep_list"
      },
      "source_output": "prompts",
      "destination_node": {
        "$component_ref": "review_gate"
      },
      "destination_input": "prompts"
    },
    {
      "component_type": "DataFlowEdge",
      "name": "run_skills_preview_to_review_gate",
      "source_node": {
        "$component_ref": "run_skills"
      },
      "source_output": "preview",
      "destination_node": {
        "$component_ref": "review_gate"
      },
      "destination_input": "preview"
    },
    {
      "component_type": "DataFlowEdge",
      "name": "review_gate_reviewResult_to_apply_exclusions",
      "source_node": {
        "$component_ref": "review_gate"
      },
      "source_output": "reviewResult",
      "destination_node": {
        "$component_ref": "apply_exclusions"
      },
      "destination_input": "reviewResult"
    },
    {
      "component_type": "DataFlowEdge",
      "name": "start_to_apply_exclusions_agent_run_id",
      "source_node": {
        "$component_ref": "start"
      },
      "source_output": "cinatra_run_id",
      "destination_node": {
        "$component_ref": "apply_exclusions"
      },
      "destination_input": "agent_run_id"
    }
  ],
  "$referenced_components": {
    "start": {
      "component_type": "StartNode",
      "id": "start",
      "name": "Inputs",
      "metadata": {
        "cinatra": {
          "required": [
            "data",
            "parentPackageName"
          ],
          "hidden": [
            "cinatra_run_id"
          ]
        }
      },
      "inputs": [
        {
          "title": "data",
          "type": "object"
        },
        {
          "title": "parentPackageName",
          "type": "string",
          "default": ""
        },
        {
          "title": "cinatra_run_id",
          "type": "string",
          "default": ""
        },
        {
          "title": "skillIds",
          "type": "array",
          "default": []
        }
      ]
    },
    "resolve_skills": {
      "component_type": "ApiNode",
      "id": "resolve_skills",
      "name": "Resolve skills",
      "url": "{{CINATRA_BASE_URL}}/api/auditor/run-skills",
      "http_method": "POST",
      "data": {
        "agent_run_id": "{{ agent_run_id }}",
        "parentPackageName": "{{ parentPackageName }}",
        "skillIds": "{{ skillIds }}",
        "data": "{{ data }}",
        "phase": "resolve"
      },
      "inputs": [
        {
          "title": "agent_run_id",
          "type": "string",
          "default": ""
        },
        {
          "title": "parentPackageName",
          "type": "string",
          "default": ""
        },
        {
          "title": "skillIds",
          "type": "array",
          "default": []
        },
        {
          "title": "data",
          "type": "object"
        }
      ],
      "outputs": [
        {
          "title": "skillIds",
          "type": "array"
        }
      ],
      "metadata": {
        "cinatra": {
          "riskClass": "read_only",
          "requiresApproval": false,
          "packageName": "@cinatra-ai/auditor-agent",
          "description": "Hybrid resolution (D-02): if input.skillIds is non-empty, use it verbatim; else call skills_installed_resolve_for_agent with parentPackageName."
        }
      }
    },
    "run_skills": {
      "component_type": "ApiNode",
      "id": "run_skills",
      "name": "Run skills",
      "url": "{{CINATRA_BASE_URL}}/api/auditor/run-skills",
      "http_method": "POST",
      "data": {
        "agent_run_id": "{{ agent_run_id }}",
        "parentPackageName": "{{ parentPackageName }}",
        "skillIds": "{{ skillIds }}",
        "data": "{{ data }}",
        "phase": "run"
      },
      "inputs": [
        {
          "title": "agent_run_id",
          "type": "string",
          "default": ""
        },
        {
          "title": "parentPackageName",
          "type": "string",
          "default": ""
        },
        {
          "title": "skillIds",
          "type": "array",
          "default": []
        },
        {
          "title": "data",
          "type": "object"
        }
      ],
      "outputs": [
        {
          "title": "preview",
          "type": "object"
        }
      ],
      "metadata": {
        "cinatra": {
          "riskClass": "read_only",
          "requiresApproval": false,
          "packageName": "@cinatra-ai/auditor-agent",
          "description": "Run skills via @cinatra-ai/llm skill-aware deterministic LLM task; persists structured SuggestionPatch[] (id, fieldPath, op, value, message) to audit_events for deterministic apply. Emits the generated personal-skill `preview` on-flow (name/description/content) WITHOUT persisting it — persistence moves to Accept per the #1794 action-boundary ruling. Per the owner per-item-accept ruling (2026-07-19), the preview also carries the proposal `patches` (each an { id, fieldPath, op, message } view of a persisted SuggestionPatch) so the renderer can offer a per-proposal accept/dismiss decision keyed by the same stable ids /api/auditor/apply replay-validates. The review gate reads the preview from this output via a DataFlowEdge; the renderer no longer calls getAuditDrawerDataAction."
        }
      }
    },
    "prep_list": {
      "component_type": "ApiNode",
      "id": "prep_list",
      "name": "Assemble HITL payload",
      "url": "{{CINATRA_BASE_URL}}/api/agents/passthrough",
      "http_method": "POST",
      "data": {
        "tool": "agent_run_hitl_prompts_list",
        "input": {},
        "agent_run_id": "{{ agent_run_id }}"
      },
      "inputs": [
        {
          "title": "agent_run_id",
          "type": "string",
          "default": ""
        }
      ],
      "outputs": [
        {
          "title": "prompts",
          "type": "array"
        }
      ],
      "metadata": {
        "cinatra": {
          "riskClass": "read_only",
          "requiresApproval": false,
          "packageName": "@cinatra-ai/auditor-agent",
          "description": "Deterministic pre-interrupt seam (#1794): run-scoped snapshot of the run's captured HITL amendment prompts via agent_run_hitl_prompts_list. Run + actor derive from the auth-injected context frame route-side; agent_run_id is bound + verified there and is NOT trusted as the scope. Output wired into review_gate.prompts."
        }
      }
    },
    "review_gate": {
      "component_type": "InputMessageNode",
      "id": "review_gate",
      "name": "Review suggestions",
      "metadata": {
        "cinatra": {
          "riskClass": "read_only",
          "requiresApproval": true,
          "renderer": "@cinatra-ai/auditor-agent:review",
          "a2uiSurfaceId": "auditor:review-gate:input",
          "autoSkipWhenInputsPresent": false,
          "description": "Per-item review (owner per-item-accept ruling, 2026-07-19): the operator decides per PROPOSED CHANGE. The renderer is a pure snapshot->onChange surface — it reads `prompts` (captured guidance) + `preview` (the generated skill preview carrying the proposal patches with stable ids) from the gate snapshot (assembled pre-interrupt) and emits a SINGLE string output `reviewResult`; it calls no host action. Because pyagentspec 26.1.2 `InputMessageNode` yields exactly one string output (`_validate_outputs_have_right_format`), every downstream channel travels inside that one JSON-encoded string — the second `excludedPromptIds` array output was removed (it is unmountable, and not fixable by the #1830 declared-inputs shim, which reconciles inputs only).",
          "inputMessageSchema": {
            "type": "object",
            "x-renderer": "@cinatra-ai/auditor-agent:review",
            "x-envelope": "json-string",
            "x-envelope-shape": {
              "acceptedPatchIds": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "dismissedPatchIds": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "excludedPromptIds": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "properties": {
              "reviewResult": {
                "type": "string",
                "title": "Review result — JSON-encoded { acceptedPatchIds, dismissedPatchIds, excludedPromptIds }. acceptedPatchIds/dismissedPatchIds are the per-item decisions over the proposal (suggestion) ids consumed by /api/auditor/apply; excludedPromptIds are the captured-guidance prompt ids the host exclude companion drops from autosave."
              }
            },
            "required": [
              "reviewResult"
            ]
          }
        }
      },
      "inputs": [
        {
          "title": "prompts",
          "type": "array",
          "default": []
        },
        {
          "title": "preview",
          "type": "object"
        }
      ],
      "outputs": [
        {
          "title": "reviewResult",
          "type": "string"
        }
      ]
    },
    "apply_exclusions": {
      "component_type": "ApiNode",
      "id": "apply_exclusions",
      "name": "Exclude dismissed prompts",
      "url": "{{CINATRA_BASE_URL}}/api/auditor/exclude",
      "http_method": "POST",
      "data": {
        "agent_run_id": "{{ agent_run_id }}",
        "reviewResult": "{{ reviewResult }}"
      },
      "inputs": [
        {
          "title": "reviewResult",
          "type": "string",
          "default": ""
        },
        {
          "title": "agent_run_id",
          "type": "string",
          "default": ""
        }
      ],
      "outputs": [
        {
          "title": "applied",
          "type": "integer"
        }
      ],
      "metadata": {
        "cinatra": {
          "riskClass": "write",
          "requiresApproval": false,
          "packageName": "@cinatra-ai/auditor-agent",
          "description": "Post-resume resume-mutation (#1794 + the per-item-accept ruling): the review gate emits ONE string output, so `excludedPromptIds` can no longer ride its own array output — and WayFlow's pyagentspec templating cannot JSON-decode a field out of a string in-graph (no `|fromjson`/`|tojson` filter). The host exclude companion at /api/auditor/exclude therefore JSON-parses the reviewResult envelope, extracts excludedPromptIds, and calls the run-bound agent_run_hitl_prompts_exclude primitive server-side. The primitive validates every id against the run's own (run, declaring-agent) prompt set and rejects the whole batch on any unknown id. Idempotent — a resumed re-run is safe. (Host companion routes to owner review.)"
        }
      }
    },
    "apply_patches": {
      "component_type": "ApiNode",
      "id": "apply_patches",
      "name": "Apply accepted patches",
      "url": "{{CINATRA_BASE_URL}}/api/auditor/apply",
      "http_method": "POST",
      "data": {
        "agent_run_id": "{{ agent_run_id }}",
        "data": "{{ data }}",
        "reviewResult": "{{ reviewResult }}"
      },
      "inputs": [
        {
          "title": "agent_run_id",
          "type": "string",
          "default": ""
        },
        {
          "title": "data",
          "type": "object"
        },
        {
          "title": "reviewResult",
          "type": "string",
          "default": ""
        }
      ],
      "outputs": [
        {
          "title": "mutatedData",
          "type": "object"
        }
      ],
      "metadata": {
        "cinatra": {
          "riskClass": "write",
          "requiresApproval": true,
          "approvalPolicy": "always",
          "packageName": "@cinatra-ai/auditor-agent",
          "description": "Deterministic applyAuditorPatches; replay-validates acceptedIds ⊆ persisted suggestions for the agent_run_id."
        }
      }
    },
    "end": {
      "component_type": "EndNode",
      "id": "end",
      "name": "End",
      "outputs": [
        {
          "title": "mutatedData",
          "type": "object"
        }
      ]
    }
  }
}
