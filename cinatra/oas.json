    },
    "resolve_skills": {
      "component_type": "ApiNode",
      "id": "resolve_skills",
      "name": "Resolve skills",
      "url": "{{CINATRA_BASE_URL}}/api/auditor/run-skills",
      "http_method": "POST",
      "data": {
        "agent_run_id": "{{ agent_run_id }}",
        "parentPackageName": "{{ parentPackageName }}",
        "skillIds": "{{ skillIds }}",
        "data": "{{ data }}",
        "phase": "resolve"
      },
      "inputs": [
        {
          "title": "agent_run_id",
          "type": "string",
          "default": ""
        },
        {
          "title": "parentPackageName",
          "type": "string",
          "default": ""
        },
        {
          "title": "skillIds",
          "type": "array",
          "default": []
        },
        {
          "title": "data",
          "type": "object"
        }
      ],
      "outputs": [
        {
          "title": "skillIds",
          "type": "array"
        }
      ],
      "metadata": {
        "cinatra": {
          "riskClass": "read_only",
          "requiresApproval": false,
          "packageName": "@cinatra-ai/auditor-agent",
          "description": "Hybrid resolution (D-02): if input.skillIds is non-empty, use it verbatim; else call skills_installed_resolve_for_agent with parentPackageName."
        }
      }
    },
    "run_skills": {
      "component_type": "ApiNode",
      "id": "run_skills",
      "name": "Run skills",
      "url": "{{CINATRA_BASE_URL}}/api/auditor/run-skills",
      "http_method": "POST",
      "data": {
        "agent_run_id": "{{ agent_run_id }}",
        "parentPackageName": "{{ parentPackageName }}",
        "skillIds": "{{ skillIds }}",
        "data": "{{ data }}",
        "phase": "run"
      },
      "inputs": [
        {
          "title": "agent_run_id",
          "type": "string",
          "default": ""
        },
        {
          "title": "parentPackageName",
          "type": "string",
          "default": ""
        },
        {
          "title": "skillIds",
          "type": "array",
          "default": []
        },
        {
          "title": "data",
          "type": "object"
        }
      ],
      "outputs": [
        {
          "title": "preview",
          "type": "object"
        },
        {
          "title": "edited",
          "type": "string"
        }
      ],
      "metadata": {
        "cinatra": {
          "riskClass": "read_only",
          "requiresApproval": false,
          "packageName": "@cinatra-ai/auditor-agent",
          "description": "Run skills via @cinatra-ai/llm skill-aware deterministic LLM task; persists structured SuggestionPatch[] (id, fieldPath, op, value, message) to audit_events for deterministic apply. Emits the generated personal-skill `preview` on-flow (name/description/content) WITHOUT persisting it \u2014 persistence moves to Accept per the #1794 action-boundary ruling. Per the owner per-item-accept ruling (2026-07-19), the preview also carries the proposal `patches` (each an { id, fieldPath, op, message } view of a persisted SuggestionPatch) so the renderer can offer a per-proposal accept/dismiss decision keyed by the same stable ids /api/auditor/apply replay-validates. The review gate reads the preview from this output via a DataFlowEdge; the renderer no longer calls getAuditDrawerDataAction. Also emits `edited` (\"edited\"|\"clean\"): the host-derived signal of whether the user applied changes to the offered artifact (the run's captured HITL amendment context + object history). The downstream `edited_gate` BranchingNode routes to the review HITL only when edited=\"edited\"; a \"clean\" run skips the gate and completes with mutatedData=data (owner ruled 2026-07-19: no user changes \u2192 no audit HITL)."
        }
      }
    },
    "edited_gate": {
      "component_type": "BranchingNode",
      "id": "edited_gate",
      "name": "Route on user-applied changes",
      "metadata": {
        "cinatra": {
          "purpose": "route-around-the-audit-HITL-when-the-user-applied-no-changes",
          "description": "Conditional trigger (owner ruling 2026-07-19): the audit review gate fires ONLY when the user applied changes to the artifact the agent offered for review. run_skills derives `edited` host-side from the run's captured HITL amendment context + the artifact's object history; this BranchingNode routes edited=\"edited\" to the review path (prep_list -> review_gate -> apply_exclusions -> apply_patches) and every other value (\"clean\") to the `default` branch straight to end, so a no-user-change run completes with mutatedData=data and NEVER surfaces the audit HITL. BranchingNode is the mount-proven predicate primitive (docker/wayflow test_skip_predicate)."
        }
      },
      "inputs": [
        {
          "title": "edited",
          "type": "string"
        }
      ],
      "outputs": [],
      "branches": [
        "default",
        "review"
      ],
      "mapping": {
        "edited": "review"
      }
    },
    "prep_list": {
      "component_type": "ApiNode",
      "id": "prep_list",
      "name": "Assemble HITL payload",
      "url": "{{CINATRA_BASE_URL}}/api/agents/passthrough",
      "http_method": "POST",
      "data": {
        "tool": "agent_run_hitl_prompts_list",
        "input": {},
        "agent_run_id": "{{ agent_run_id }}"
      },
      "inputs": [
        {
          "title": "agent_run_id",
          "type": "string",
          "default": ""
        }
      ],
      "outputs": [
        {
          "title": "prompts",
          "type": "array"
        }
      ],
      "metadata": {
        "cinatra": {
          "riskClass": "read_only",
          "requiresApproval": false,
          "packageName": "@cinatra-ai/auditor-agent",
          "description": "Deterministic pre-interrupt seam (#1794): run-scoped snapshot of the run's captured HITL amendment prompts via agent_run_hitl_prompts_list. Run + actor derive from the auth-injected context frame route-side; agent_run_id is bound + verified there and is NOT trusted as the scope. Output wired into review_gate.prompts."
        }
      }
    },
    "review_gate": {
      "component_type": "InputMessageNode",
      "id": "review_gate",
      "name": "Review suggestions",
      "metadata": {
        "cinatra": {
          "riskClass": "read_only",
          "requiresApproval": true,
          "renderer": "@cinatra-ai/auditor-agent:review",
          "a2uiSurfaceId": "auditor:review-gate:input",
          "autoSkipWhenInputsPresent": false,
          "description": "Per-item review (owner per-item-accept ruling, 2026-07-19): the operator decides per PROPOSED CHANGE. The renderer is a pure snapshot->onChange surface \u2014 it reads `prompts` (captured guidance) + `preview` (the generated skill preview carrying the proposal patches with stable ids) from the gate snapshot (assembled pre-interrupt) and emits a SINGLE string output `reviewResult`; it calls no host action. Because pyagentspec 26.1.2 `InputMessageNode` yields exactly one string output (`_validate_outputs_have_right_format`), every downstream channel travels inside that one JSON-encoded string \u2014 the second `excludedPromptIds` array output was removed (it is unmountable, and not fixable by the #1830 declared-inputs shim, which reconciles inputs only).",
          "inputMessageSchema": {
            "type": "object",
            "x-renderer": "@cinatra-ai/auditor-agent:review",
            "x-envelope": "json-string",
            "x-envelope-shape": {
              "acceptedPatchIds": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "dismissedPatchIds": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "excludedPromptIds": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "properties": {
              "reviewResult": {
                "type": "string",
                "title": "Review result \u2014 JSON-encoded { acceptedPatchIds, dismissedPatchIds, excludedPromptIds }. acceptedPatchIds/dismissedPatchIds are the per-item decisions over the proposal (suggestion) ids consumed by /api/auditor/apply; excludedPromptIds are the captured-guidance prompt ids the host exclude companion drops from autosave."
              }
            },
            "required": [
              "reviewResult"
            ]
          }
        }
      },
      "inputs": [
        {
          "title": "prompts",
          "type": "array",
          "default": []
        },
        {
          "title": "preview",
          "type": "object"
        }
      ],
      "outputs": [
        {
          "title": "reviewResult",
          "type": "string"
        }
      ]
    },
    "apply_exclusions": {
      "component_type": "ApiNode",
      "id": "apply_exclusions",
      "name": "Exclude dismissed prompts",
      "url": "{{CINATRA_BASE_URL}}/api/auditor/exclude",
      "http_method": "POST",
      "data": {
        "agent_run_id": "{{ agent_run_id }}",
        "reviewResult": "{{ reviewResult }}"
      },
      "inputs": [
        {
          "title": "reviewResult",
          "type": "string",
          "default": ""
        },
        {
          "title": "agent_run_id",
          "type": "string",
          "default": ""
        }
      ],
      "outputs": [
        {
          "title": "applied",
          "type": "integer"
        }
      ],
      "metadata": {
        "cinatra": {
          "riskClass": "write",
          "requiresApproval": false,
          "packageName": "@cinatra-ai/auditor-agent",
          "description": "Post-resume resume-mutation (#1794 + the per-item-accept ruling): the review gate emits ONE string output, so `excludedPromptIds` can no longer ride its own array output \u2014 and WayFlow's pyagentspec templating cannot JSON-decode a field out of a string in-graph (no `|fromjson`/`|tojson` filter). The host exclude companion at /api/auditor/exclude therefore JSON-parses the reviewResult envelope, extracts excludedPromptIds, and calls the run-bound agent_run_hitl_prompts_exclude primitive server-side. The primitive validates every id against the run's own (run, declaring-agent) prompt set and rejects the whole batch on any unknown id. Idempotent \u2014 a resumed re-run is safe. (Host companion routes to owner review.)"
        }
      }
    },
    "apply_patches": {
      "component_type": "ApiNode",
      "id": "apply_patches",
      "name": "Apply accepted patches",
      "url": "{{CINATRA_BASE_URL}}/api/auditor/apply",
      "http_method": "POST",
      "data": {
        "agent_run_id": "{{ agent_run_id }}",
        "parentPackageName": "{{ parentPackageName }}",
        "data": "{{ data }}",
        "reviewResult": "{{ reviewResult }}"
      },
      "inputs": [
        {
          "title": "agent_run_id",
          "type": "string",
          "default": ""
        },
        {
          "title": "data",
          "type": "object"
        },
        {
          "title": "reviewResult",
          "type": "string",
          "default": ""
        },
        {
          "title": "parentPackageName",
          "type": "string",
          "default": ""
        }
      ],
      "outputs": [
        {
          "title": "mutatedData",
          "type": "object"
        }
      ],
      "metadata": {
        "cinatra": {
          "riskClass": "write",
          "requiresApproval": true,
          "approvalPolicy": "always",
          "packageName": "@cinatra-ai/auditor-agent",
          "description": "Deterministic applyAuditorPatches; replay-validates acceptedIds \u2286 persisted suggestions for the agent_run_id. Carries parentPackageName so /api/auditor/apply can persist the accepted per-item skill changes for the parent agent at Accept (owner per-item-accept ruling, 2026-07-19)."
        }
      }
    },
    "end": {
      "component_type": "EndNode",
      "id": "end",
      "name": "End",
      "outputs": [
        {
          "title": "mutatedData",
          "type": "object"
        }
      ]
    }
  }
}
